<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Meds Tracker Pro - Final List</title>
    
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore-compat.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>
    
    <style>
        :root { --bg: #0f172a; --card: #1e293b; --accent: #3b82f6; --danger: #ef4444; --success: #10b981; --text: #f1f5f9; }
        body { font-family: -apple-system, sans-serif; background: var(--bg); color: var(--text); padding: 10px; margin: 0; }
        .container { max-width: 400px; margin: auto; }
        
        #alarmPanel { 
            display: none; background: var(--card); color: white; padding: 20px; 
            border-radius: 0 0 20px 20px; text-align: center; 
            position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); border-bottom: 3px solid var(--danger);
        }
        .stop-btn { background: var(--danger); color: white; padding: 15px; border-radius: 10px; font-weight: bold; margin-top: 10px; cursor: pointer; border: none; width: 100%; font-size: 16px; }
        .snooze-btn { background: var(--accent); color: white; padding: 10px; border-radius: 10px; margin-top: 10px; cursor: pointer; border: none; width: 100%; }

        .input-card { background: var(--card); padding: 15px; border-radius: 15px; border: 1px solid #334155; margin-bottom: 15px; }
        input, .btn { width: 100%; padding: 10px; margin-top: 8px; border-radius: 8px; border: 1px solid #334155; background: #0f172a; color: white; box-sizing: border-box; }
        .btn { background: var(--accent); border: none; font-weight: bold; height: 45px; cursor: pointer; }
        .btn-pdf { background: var(--success); margin-top: 10px; border: none; font-size: 14px; }
        #searchBox { background: #1e293b; border: 1px solid var(--accent); margin-bottom: 15px; }

        .med-item { background: var(--card); border-radius: 12px; padding: 12px; margin-bottom: 10px; border-left: 5px solid var(--accent); overflow: hidden; }
        .med-header { display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
        .time-badge { background: #0f172a; padding: 4px 10px; border-radius: 6px; font-size: 14px; color: var(--accent); font-weight: bold; }

        .schedule-content { display: none; margin-top: 15px; border-top: 1px solid #334155; padding-top: 10px; }
        .calendar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(40px, 1fr)); gap: 5px; }
        .day-box { background: #0f172a; padding: 8px; border-radius: 6px; text-align: center; font-size: 11px; border: 1px solid #334155; }
        .day-box.taken { background: var(--success); color: white; border-color: #10b981; }

        .settings-row { display: flex; gap: 5px; margin-top: 10px; flex-wrap: wrap; }
        .opt-box { flex: 1; min-width: 60px; background: #0f172a; padding: 5px; border-radius: 5px; text-align: center; font-size: 10px; border: 1px solid #334155; }
        .del-btn { color: #64748b; background: none; border: none; font-size: 18px; cursor: pointer; margin-left: 10px; }
        #status { font-size: 11px; text-align: center; color: #94a3b8; margin-bottom: 10px; font-weight: bold; }
    </style>
</head>
<body onclick="initSystem()">

<div class="container">
    <div id="alarmPanel">
        <h2 id="alarmTitle" style="margin:0; color:var(--danger);">MEDICINE TIME!</h2>
        <p id="alarmMedName" style="font-size:18px; margin:10px 0; font-weight: bold;"></p>
        <button class="stop-btn" onclick="permanentStop()">🛑 STOP FOR TODAY</button>
        <button class="snooze-btn" onclick="silence()">⏳ SNOOZE / WAIT</button>
    </div>

    <div id="status">⚠️ Tap anywhere to Start System</div>

    <div class="input-card">
        <input type="text" id="mName" placeholder="Medicine Name">
        <input type="time" id="mTime">
        <div style="display: flex; gap: 5px;">
            <input type="date" id="sDate" style="flex:1">
            <input type="date" id="eDate" style="flex:1">
        </div>
        <input type="file" id="mFile" accept="audio/*">
        <div class="settings-row">
            <div class="opt-box">🔊 Audio <br> <input type="checkbox" id="cSnd" checked></div>
            <div class="opt-box">📳 Vib <br> <input type="checkbox" id="cVib" checked></div>
            <div class="opt-box">🗣️ Voice <br> <input type="checkbox" id="cVce" checked></div>
            <div class="opt-box" style="border-color: var(--accent);">🔁 Persistent <br> <input type="checkbox" id="cRep" checked></div>
        </div>
        <button class="btn" onclick="addMed()">Save Schedule</button>
        <button class="btn btn-pdf" onclick="downloadHistoryPDF()">📥 Download History (PDF)</button>
    </div>

    <input type="text" id="searchBox" placeholder="Search medicine..." onkeyup="filterMeds()">
    <div id="list"></div>
</div>

<audio id="alarmAudio" loop></audio>

<script>
    // Firebase Config (Keep as is)
    const firebaseConfig = {
      apiKey: "AIzaSyCBUF6IDj-YVEFovPjg9LvI7NOHhYEU_HE",
      authDomain: "medstracker-2f8d8.firebaseapp.com",
      projectId: "medstracker-2f8d8",
      storageBucket: "medstracker-2f8d8.firebasestorage.app",
      messagingSenderId: "689229781527",
      appId: "1:689229781527:web:9b55a840aed8368d2c5a52"
    };

    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();
    const audio = document.getElementById('alarmAudio');

    let firing = false;
    let vibLoop = null;
    let persistentInterval = null; // New variable for repetition
    let currentMedId = null;
    let stoppedToday = JSON.parse(localStorage.getItem('stoppedAlarms')) || {};

    async function initSystem() {
        if ("Notification" in window) { Notification.requestPermission(); }
        audio.play().then(() => audio.pause()).catch(() => {});
        document.getElementById('status').innerText = "● SYSTEM ACTIVE";
        document.getElementById('status').style.color = "#10b981";
    }

    // PDF Download
    async function downloadHistoryPDF() {
        try {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.text("Medication History Report", 14, 20);
            const snapshot = await db.collection("medicines").get();
            const rows = [];
            snapshot.forEach(docSnap => {
                const data = docSnap.data();
                if (data.taken) data.taken.forEach(date => rows.push([date, data.name, "✅ Taken"]));
            });
            doc.autoTable({ head: [['Date', 'Medicine', 'Status']], body: rows, startY: 30 });
            doc.save("Meds_History.pdf");
        } catch (e) { alert(e.message); }
    }

    async function addMed() {
        const n=document.getElementById('mName').value, t=document.getElementById('mTime').value, s=document.getElementById('sDate').value, e=document.getElementById('eDate').value, f=document.getElementById('mFile').files[0];
        if(!n || !t) return alert("Details missing");
        let sd = f ? await toB64(f) : "";
        db.collection("medicines").add({ 
            name:n, time:t, start:s, end:e, sound:sd, 
            useSnd:document.getElementById('cSnd').checked, 
            useVib:document.getElementById('cVib').checked, 
            useVce:document.getElementById('cVce').checked, 
            repeat:document.getElementById('cRep').checked,
            taken:[] 
        });
    }

    const toB64 = f => new Promise(r => { const rd=new FileReader(); rd.readAsDataURL(f); rd.onload=()=>r(rd.result); });

    db.collection("medicines").onSnapshot(snap => {
        document.getElementById('list').innerHTML = "";
        snap.forEach(doc => {
            render(doc.id, doc.data());
            monitor(doc.id, doc.data());
        });
    });

    function render(id, data) {
        let cal = "";
        let curr = new Date(data.start), last = new Date(data.end);
        while(curr <= last) {
            const dStr = curr.toDateString(), isT = data.taken.includes(dStr);
            cal += `<div class="day-box ${isT?'taken':''}" onclick="markTaken('${id}','${dStr}')">${curr.getDate()}</div>`;
            curr.setDate(curr.getDate() + 1);
        }
        const html = `<div class="med-item"><div class="med-header" onclick="toggleList('${id}')"><div><strong>${data.name}</strong></div><div><span class="time-badge">${data.time}</span><button class="del-btn" onclick="event.stopPropagation(); del('${id}')">🗑️</button></div></div><div class="schedule-content" id="list-${id}"><div class="calendar-grid">${cal}</div></div></div>`;
        document.getElementById('list').insertAdjacentHTML('beforeend', html);
    }

    function toggleList(id) {
        const el = document.getElementById('list-' + id);
        el.style.display = (el.style.display === "block") ? "none" : "block";
    }

    function monitor(id, data) {
        setInterval(() => {
            const now = new Date();
            const timeNow = now.getHours().toString().padStart(2,'0')+":"+now.getMinutes().toString().padStart(2,'0');
            const today = now.toDateString();
            if (stoppedToday[id] === today || firing) return; 
            if(timeNow === data.time && !data.taken.includes(today)) {
                fireAlarm(id, data);
            }
        }, 1000);
    }

    // UPDATED ALARM LOGIC (With 20s Repeat)
    function fireAlarm(id, data) {
        firing = true; 
        currentMedId = id;
        document.getElementById('alarmMedName').innerText = data.name;
        document.getElementById('alarmPanel').style.display = "block";

        const startAlert = () => {
            if(data.useSnd && data.sound) { audio.src = data.sound; audio.play().catch(()=>{}); }
            if(data.useVce) { window.speechSynthesis.cancel(); window.speechSynthesis.speak(new SpeechSynthesisUtterance("Medicine time for " + data.name)); }
            if(data.useVib && navigator.vibrate) navigator.vibrate([600,200,600]);
        };

        startAlert();

        if (data.repeat) {
            clearInterval(persistentInterval);
            persistentInterval = setInterval(() => {
                if (firing) startAlert();
            }, 20000); // 20 Seconds
        }
    }

    function permanentStop() {
        if (!currentMedId) return;
        stoppedToday[currentMedId] = new Date().toDateString();
        localStorage.setItem('stoppedAlarms', JSON.stringify(stoppedToday));
        silence();
    }

    function silence() {
        firing = false; 
        clearInterval(persistentInterval); 
        audio.pause(); audio.src = "";
        window.speechSynthesis.cancel(); 
        document.getElementById('alarmPanel').style.display = "none";
    }

    function markTaken(id, dStr) {
        const ref = db.collection("medicines").doc(id);
        ref.get().then(doc => {
            let t = doc.data().taken || [];
            if(t.includes(dStr)) ref.update({ taken: firebase.firestore.FieldValue.arrayRemove(dStr) });
            else ref.update({ taken: firebase.firestore.FieldValue.arrayUnion(dStr) });
        });
    }

    function del(id) { if(confirm("Delete?")) db.collection("medicines").doc(id).delete(); }
    function filterMeds() { /* Same as before */ }
</script>
</body>
</html>
